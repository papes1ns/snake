#!/usr/bin/env node

import path from 'node:path';
import fs from 'node:fs';
import os from 'node:os';
import { fork } from 'node:child_process';
import { fileURLToPath } from 'node:url';
import GeneticAlgorithm from '../src/genetic.js';
import GameCore from '../src/game_core.js';

var __dirname = path.dirname(fileURLToPath(import.meta.url));

var args           = parseArgs(process.argv.slice(2));
var generations    = parseInt(args.generations || args.g) || 100;
var populationSize = parseInt(args.population  || args.p) || 1000;
var gamesPerEval   = parseInt(args.games)                 || 8;
var timeLimitSec   = parseInt(args.time || args.t)        || 0;
var numWorkers     = parseInt(args.workers)               || Math.max(1, os.cpus().length - 1);
var outputPath     = args.output || args.o || path.join(__dirname, '..', 'models', 'best.json');

numWorkers = Math.min(numWorkers, populationSize);

GameCore.setTimeLimit(timeLimitSec * 1000);

console.log('Snake AI - Neuroevolution Training');
console.log('-----------------------------------');
console.log('Population:  ' + populationSize);
console.log('Generations: ' + generations);
console.log('Games/eval:  ' + gamesPerEval);
console.log('Time limit:  ' + timeLimitSec + 's');
console.log('Workers:     ' + numWorkers);
console.log('Output:      ' + outputPath);
console.log('');

var outputDir = path.dirname(outputPath);
if (!fs.existsSync(outputDir)) {
  fs.mkdirSync(outputDir, { recursive: true });
}

var ga = new GeneticAlgorithm({
  populationSize: populationSize,
  gamesPerEval:   gamesPerEval
});

if (numWorkers <= 1) {
  trainSingleThread();
} else {
  trainParallel();
}

// ---------- single-threaded fallback ----------

function trainSingleThread() {
  var overallBestScore = 0;

  for (var gen = 0; gen < generations; gen++) {
    var startTime = Date.now();
    var stats     = ga.evolve();
    var elapsed   = ((Date.now() - startTime) / 1000).toFixed(1);

    if (stats.bestScore > overallBestScore) {
      overallBestScore = stats.bestScore;
    }

    logGeneration(stats, elapsed);
    saveModel();
  }

  logComplete(overallBestScore);
}

// ---------- parallel training ----------

function trainParallel() {
  var workerPath = path.join(__dirname, '..', 'src', 'worker.js');
  var workers    = [];
  var readyCount = 0;

  for (var i = 0; i < numWorkers; i++) {
    var w = fork(workerPath, [], { stdio: 'ignore' });
    w.on('error', function(err) { console.error('Worker error:', err); });
    workers.push(w);
  }

  // Initialize all workers with time limit, then start training
  var initDone = 0;
  for (var i = 0; i < workers.length; i++) {
    (function(worker) {
      function onInit(msg) {
        if (msg.type === 'ready') {
          worker.removeListener('message', onInit);
          initDone++;
          if (initDone === workers.length) {
            runGenerations(workers, 0, 0);
          }
        }
      }
      worker.on('message', onInit);
      worker.send({ type: 'init', timeLimit: timeLimitSec * 1000 });
    })(workers[i]);
  }

  function runGenerations(workers, gen, overallBestScore) {
    if (gen >= generations) {
      logComplete(overallBestScore);
      for (var i = 0; i < workers.length; i++) workers[i].kill();
      process.exit(0);
      return;
    }

    var startTime = Date.now();

    evaluateParallel(workers, function(fitnesses) {
      var stats   = ga.evolveFromResults(fitnesses);
      var elapsed = ((Date.now() - startTime) / 1000).toFixed(1);

      if (stats.bestScore > overallBestScore) {
        overallBestScore = stats.bestScore;
      }

      logGeneration(stats, elapsed);
      saveModel();

      // Use setImmediate to avoid stack overflow on deep recursion
      setImmediate(function() {
        runGenerations(workers, gen + 1, overallBestScore);
      });
    });
  }
}

function evaluateParallel(workers, callback) {
  var populationData = ga.getPopulationData();
  var chunkSize      = Math.ceil(populationData.length / workers.length);
  var allResults     = new Array(populationData.length);
  var expected       = 0;
  var completed      = 0;

  for (var w = 0; w < workers.length; w++) {
    var start = w * chunkSize;
    var end   = Math.min(start + chunkSize, populationData.length);
    var batch = populationData.slice(start, end);

    if (batch.length === 0) continue;
    expected++;

    (function(worker, batchRef) {
      function onMessage(msg) {
        if (msg.type === 'results') {
          worker.removeListener('message', onMessage);
          for (var i = 0; i < msg.results.length; i++) {
            var r = msg.results[i];
            allResults[r.id] = { fitness: r.fitness, score: r.score };
          }
          completed++;
          if (completed === expected) callback(allResults);
        }
      }
      worker.on('message', onMessage);
      worker.send({
        type:         'evaluate',
        batch:        batchRef,
        gamesPerEval: gamesPerEval
      });
    })(workers[w], batch);
  }
}

// ---------- shared helpers ----------

function logGeneration(stats, elapsed) {
  var line = 'Gen ' + pad(stats.generation, 4) +
    ' | Score: ' + pad(stats.bestScore, 3) +
    ' | Best Fit: ' + pad(stats.bestFitness.toFixed(0), 8) +
    ' | Avg Fit: '  + pad(stats.avgFitness.toFixed(0), 8) +
    ' | Top: [' + stats.topScores.join(', ') + ']' +
    ' | ' + elapsed + 's';
  console.log(line);
}

function saveModel() {
  if (ga.bestNet) {
    fs.writeFileSync(outputPath, JSON.stringify(ga.bestNet.toJSON()));
  }
}

function logComplete(overallBestScore) {
  console.log('');
  console.log('Training complete.');
  console.log('Best score achieved: ' + overallBestScore);
  console.log('Model saved to: ' + outputPath);
}

function pad(val, width) {
  var s = String(val);
  while (s.length < width) s = ' ' + s;
  return s;
}

function parseArgs(argv) {
  var result = {};
  for (var i = 0; i < argv.length; i++) {
    if (argv[i].indexOf('--') === 0) {
      var key = argv[i].slice(2);
      var val = argv[i + 1] && argv[i + 1].indexOf('--') !== 0 ? argv[++i] : true;
      result[key] = val;
    } else if (argv[i].indexOf('-') === 0 && argv[i].length === 2) {
      var k = argv[i].slice(1);
      var v = argv[i + 1] && argv[i + 1].indexOf('-') !== 0 ? argv[++i] : true;
      result[k] = v;
    }
  }
  return result;
}
